# StarkPay Web Environment Variables

# --- SDK Configuration ---
# Your AVNU API Key for gasless transactions/paymaster support
# Get one at: https://www.avnu.fi/
NEXT_PUBLIC_AVNU_API_KEY=your_avnu_api_key_here

# Starknet Network: 'mainnet' or 'sepolia'
NEXT_PUBLIC_STARKNET_NETWORK=sepolia

# --- Backend Integration ---
# Your backend URL for wallet resolution and sponsored transactions
NEXT_PUBLIC_BACKEND_URL=https://api.yourstarkpaybackend.com

# --- Confidential Payments (Tongo) ---
# Tongo Contract Address (Network specific)
# Sepolia: 0x...
# Mainnet: 0x...
NEXT_PUBLIC_TONGO_CONTRACT_ADDRESS=0x02758d8b...

# Sensitive: Tongo Private Key (separate from Starknet key)
# DO NOT COMMIT ACTUAL KEYS TO VERSION CONTROL
# Note: On the web, sensitive keys should ideally be fetched from a secure vault or derived on-the-fly.
TONGO_PRIVATE_KEY=your_tongo_private_key_here
