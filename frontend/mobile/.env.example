# StarkPay Mobile Environment Variables

# --- SDK Configuration ---
# Your AVNU API Key for gasless transactions/paymaster support
# Get one at: https://www.avnu.fi/
AVNU_API_KEY=your_avnu_api_key_here

# Starknet Network: 'mainnet' or 'sepolia'
STARKNET_NETWORK=sepolia

# --- Backend Integration ---
# Your backend URL for Privy wallet resolution and sponsored transactions
BACKEND_URL=https://api.yourstarkpaybackend.com

# --- Confidential Payments (Tongo) ---
# Tongo Contract Address (Network specific)
# Sepolia: 0x...
# Mainnet: 0x...
TONGO_CONTRACT_ADDRESS=0x02758d8b...

# Sensitive: Tongo Private Key (separate from Starknet key)
# DO NOT COMMIT ACTUAL KEYS TO VERSION CONTROL
TONGO_PRIVATE_KEY=your_tongo_private_key_here
